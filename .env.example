# ICT Lab Platform - 环境变量配置
# 复制此文件为 .env，并填入实际值

# PostgreSQL 密码（强密码，至少16位）
DB_PASSWORD=change-this-strong-password

# JWT 密钥（随机字符串，至少32位）
# 生成命令：openssl rand -base64 32
JWT_SECRET=change-this-jwt-secret

# 前端构建时的 API 地址（宝塔 Nginx 代理后的完整域名）
# 例如：https://yourdomain.com/api
VITE_API_URL=https://your-domain.com/api
